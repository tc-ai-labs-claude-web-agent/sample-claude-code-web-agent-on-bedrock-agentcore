# AWS Configuration
AWS_REGION=ap-southeast-2
AWS_ACCOUNT_ID=

# Project Configuration
PROJECT_NAME=claude-agent-api-server
DEPLOYMENT_ENV=prod

# Docker/ECR Configuration
ECR_REPOSITORY_NAME=agentcore/claude-code
DOCKER_IMAGE_VERSION=latest
# Note: Docker images are built for ARM64 architecture (required by Bedrock AgentCore)

# AgentCore Runtime Configuration
AGENT_RUNTIME_NAME=claude_code
IAM_ROLE_NAME=AmazonBedrockAgentCoreSDKRuntime
S3_WORKSPACE_BUCKET_PREFIX=agentcore
# Note: Actual bucket name will be: agentcore-{region}-{account_id}

# Cognito/Auth Configuration (for AgentCore JWT authorizer)
# Leave empty to auto-create new Cognito User Pool and Client
# Or provide existing Cognito configuration:
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DISCOVERY_URL=
COGNITO_REGION=

# Optional: Custom names for auto-created Cognito resources
# COGNITO_USER_POOL_NAME=ClaudeAgentPool-prod
# COGNITO_CLIENT_NAME=ClaudeAgentClient-prod

# Bedrock Model Configuration
ANTHROPIC_MODEL=global.anthropic.claude-sonnet-4-6
ANTHROPIC_SMALL_FAST_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
ANTHROPIC_DEFAULT_HAIKU_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
DISABLE_PROMPT_CACHING=0
CLAUDE_CODE_USE_BEDROCK=1

# Claude Agent SDK Tools Configuration
# ALLOWED_TOOLS: Comma-separated list of tools to enable in agent sessions
# Leave empty to enable all tools (default)
# Available tools: Read, Write, Edit, Glob, Grep, Bash, NotebookEdit, WebFetch,
#                  Task, TodoWrite, BashOutput, KillShell, AskUserQuestion,
#                  Skill, SlashCommand, ExitPlanMode, ListMcpResourcesTool, ReadMcpResourceTool
# ALLOWED_TOOLS=Read,Write,Edit,Glob,Grep,Bash

# AUTO_ALLOW_TOOLS: Comma-separated list of tools to auto-approve without user permission
# Leave empty to use default (Read, Write, Edit, Bash, Glob, Grep)
# Example: AUTO_ALLOW_TOOLS=Read,Glob,Grep
# AUTO_ALLOW_TOOLS=

# Available Models for Web Client
# Comma-separated list of models to show in the web client model selector
AVAILABLE_MODELS=global.anthropic.claude-sonnet-4-6,global.anthropic.claude-haiku-4-5-20251001-v1:0
# Lets not use Qwen for now: ,qwen.qwen3-coder-480b-a35b-v1:0

# Amplify Configuration
AMPLIFY_APP_NAME=claude-agent-web-client
AMPLIFY_BRANCH_NAME=main
GITHUB_REPO=https://github.com/aws-samples/sample-claude-code-web-agent-on-bedrock-agentcore.git

# Email Domain Restriction (for Amplify frontend)
# Comma-separated list of allowed email domains for user registration
# Example: gmail.com,outlook.com,company.com
# Leave empty or unset to allow all email domains (no restriction)
# VITE_ALLOWED_EMAIL_DOMAINS=gmail.com,outlook.com

# OAuth Configuration
OAUTH_CALLBACK_URL=http://localhost:8080/oauth/callback

# GitHub OAuth Configuration (for AgentCore Identity Provider)
# REQUIRED for GitHub integration features
# Steps to obtain:
# 1. Go to GitHub Settings -> Developer settings -> OAuth Apps
#    URL: https://github.com/settings/developers
# 2. Create a new OAuth App with callback URL:
#    https://bedrock-agentcore.<REGION>.amazonaws.com/identities/oauth2/callback
#    Replace <REGION> with your AWS region (e.g., ap-southeast-2)
# 3. Copy Client ID and generate Client Secret
# 4. Fill in the values below:
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Tags (optional)
TAG_ENVIRONMENT=production
TAG_PROJECT=claude-agent
TAG_MANAGED_BY=deployment-script
